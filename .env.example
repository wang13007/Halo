GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"
APP_URL="MY_APP_URL"
# Leave empty for same-origin deployments and local `npm run dev` proxying.
# Only set this when the frontend must call a separately hosted backend.
VITE_API_BASE_URL=""
API_PORT="8787"

# Supabase project URL, for example: https://your-project-ref.supabase.co
SUPABASE_URL="https://your-project-ref.supabase.co"

# Optional public key for future frontend direct access.
SUPABASE_ANON_KEY="your-anon-key"

# Server-side key, used only by the Express backend.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Direct Postgres connection string from Supabase, used by `npm run db:setup`.
SUPABASE_DB_URL="postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres"

# Optional comma-separated CORS allow list for custom deployments.
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500"

# Longfor EMS queryReport upstream endpoint.
LONGFOR_QUERY_REPORT_URL="https://gwp0-hw.longfor.com/yunjing-prod/qd-ems-analysis/api/v1/analysis/energy/queryReport"

# Longfor EMS Authorization header value.
LONGFOR_AUTHORIZATION="TGT-xxxxxxxxxxxxxxxx"

# Longfor EMS x-gaia-api-key header value.
LONGFOR_X_GAIA_API_KEY="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Longfor EMS CASTGC ticket. Supports raw ticket, CASTGC=..., or CASTGC:...
LONGFOR_CASTGC="TGT-xxxxxxxxxxxxxxxx"
