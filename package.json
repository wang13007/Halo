{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" vite --port=3000 --host=0.0.0.0",
    "dev:server": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" tsx watch server/index.ts",
    "build": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" vite build",
    "preview": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" vite preview --host=0.0.0.0",
    "start": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" tsx server/index.ts",
    "db:setup": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" tsx scripts/setup-supabase.ts",
    "clean": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" clean",
    "lint": "node -e \"const path=require('path');const {spawnSync}=require('child_process');const root=path.dirname(process.env.npm_package_json);const cli=path.join(root,'scripts','run-local-cli.cjs');const result=spawnSync(process.execPath,[cli,...process.argv.slice(1)],{stdio:'inherit',cwd:root});process.exit(result.status ?? 1)\" tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
