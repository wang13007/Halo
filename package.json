{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" vite --port=3000 --host=0.0.0.0",
    "dev:server": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" tsx watch server/index.ts",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" vite build",
    "preview": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" vite preview --host=0.0.0.0",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" tsx server/index.ts",
    "db:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" tsx scripts/setup-supabase.ts",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" clean",
    "lint": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%npm_package_json:package.json=scripts\\npm-runner.ps1%\" tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
